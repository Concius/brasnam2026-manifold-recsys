    "## 11. Consolida\u00e7\u00e3o \u2014 Amazon-Book\n",
    "\n",
    "Carrega os tr\u00eas JSONs por seed (`table_b_amazon_seed_2020.json`, `..._2021.json`, `..._2022.json`) e produz a tabela final agregada com m\u00e9dia \u00b1 desvio padr\u00e3o sobre as tr\u00eas seeds, tanto para m\u00e9tricas de recomenda\u00e7\u00e3o quanto para NP@10/LDD@10.\n",
    "\n",
    "Esta \u00e9 a vers\u00e3o correta para citar no paper (em vez de qualquer JSON individual por seed)."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Merge per-seed Amazon-Book JSONs into a single aggregated table\n",
    "\n",
    "from glob import glob\n",
    "\n",
    "amazon_jsons = sorted(glob(str(Path(SAVE_DIR) / 'table_b_amazon_seed_*.json')))\n",
    "print(f\"Found {len(amazon_jsons)} per-seed JSONs for amazon-book:\")\n",
    "for p in amazon_jsons:\n",
    "    print(f\"  - {Path(p).name}\")\n",
    "\n",
    "if len(amazon_jsons) == 0:\n",
    "    print(\"\\n  Nothing to merge yet \u2014 run the three Amazon-Book cells above first.\")\n",
    "else:\n",
    "    # Per-seed metric records\n",
    "    lightgcn_per_seed = []  # list of {metric: scalar}\n",
    "    kgat_per_seed = []\n",
    "    lightgcn_geom_per_seed = []  # list of {'NP@k': v, 'LDD@k': v}\n",
    "    kgat_geom_per_seed = []\n",
    "    seeds_used = []\n",
    "\n",
    "    for p in amazon_jsons:\n",
    "        with open(p) as f:\n",
    "            d = json.load(f)\n",
    "        seed_used = int(d['_metadata']['hyperparameters']['seeds'][0])\n",
    "        seeds_used.append(seed_used)\n",
    "\n",
    "        # Recommendation metrics: each per-seed JSON has 1-run aggregates (mean == raw[0])\n",
    "        tb = d['table_b_amazon']['amazon-book']\n",
    "        lightgcn_per_seed.append({k: v['mean'] for k, v in tb['lightgcn'].items()})\n",
    "        kgat_per_seed.append({k: v['mean'] for k, v in tb['kgat'].items()})\n",
    "\n",
    "        # Geometric metrics\n",
    "        geom_models = d['geom_b_amazon']['amazon-book'][str(seed_used)]\n",
    "        for m in geom_models:\n",
    "            if m['model'] == 'LightGCN':\n",
    "                lightgcn_geom_per_seed.append({'NP@k': m['NP@k'], 'LDD@k': m['LDD@k']})\n",
    "            elif m['model'] == 'KGAT':\n",
    "                kgat_geom_per_seed.append({'NP@k': m['NP@k'], 'LDD@k': m['LDD@k']})\n",
    "\n",
    "    def aggregate_records(records):\n",
    "        if not records:\n",
    "            return {}\n",
    "        keys = records[0].keys()\n",
    "        return {k: {'mean': float(np.mean([r[k] for r in records])),\n",
    "                    'std': float(np.std([r[k] for r in records])),\n",
    "                    'n_runs': len(records),\n",
    "                    'raw': [float(r[k]) for r in records]} for k in keys}\n",
    "\n",
    "    merged_amazon = {\n",
    "        'amazon-book': {\n",
    "            'lightgcn': aggregate_records(lightgcn_per_seed),\n",
    "            'kgat': aggregate_records(kgat_per_seed),\n",
    "        }\n",
    "    }\n",
    "    merged_geom = {\n",
    "        'amazon-book': {\n",
    "            'LightGCN': aggregate_records(lightgcn_geom_per_seed),\n",
    "            'KGAT': aggregate_records(kgat_geom_per_seed),\n",
    "        }\n",
    "    }\n",
    "\n",
    "    save_results(\n",
    "        {\n",
    "            'table_b_amazon_merged': merged_amazon,\n",
    "            'geom_b_amazon_merged': merged_geom,\n",
    "            'merged_from_seeds': sorted(seeds_used),\n",
    "        },\n",
    "        Path(SAVE_DIR) / 'table_b_amazon_merged.json',\n",
    "        hyperparameters=get_hyperparameters('random_80_20', 'amazon-book',\n",
    "                                            seeds=sorted(seeds_used)),\n",
    "    )\n",
